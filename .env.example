# SerpApi API Key（从 https://serpapi.com/manage-api-key 获取）
# 本工具产出仅供研究参考，不构成投资建议。
SERPAPI_KEY=your_api_key_here

# 可选：覆盖默认端点（默认 https://serpapi.com/search.json）
# SERPAPI_ENDPOINT=https://serpapi.com/search.json

# 批量检索并行度（batch-search-fetch.sh）
# PARALLEL_JOBS=8
# MAX_FETCH=5
# FETCH_PARALLEL=5
# MAX_CHARS=500000
